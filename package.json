{
  "name": "soundmaster",
  "version": "1.0.0",
  "description": "",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i css/input.css -o css/styles.css --watch",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.soundmaster.app",
    "productName": "SoundMaster",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "localtunnel": "^2.0.2",
    "nedb": "^1.8.0",
    "socket.io": "^4.8.3",
    "soundcraft-ui-connection": "^6.0.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.4"
  }
}
