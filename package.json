{
  "name": "soundmaster",
  "version": "1.0.0",
  "description": "",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i css/input.css -o css/styles.css --watch",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node tests/audit-tests.js",
    "testbed": "node tests/testbed.js",
    "audit": "node tests/audit-tests.js",
    "audit:quick": "echo 'Use: npm run audit para rodar auditoria completa' && echo 'Abra AUDIT_INTERACTIVE.html para teste visual interativo' && echo 'Consulte AUDIT_GUIDE.md para instruções detalhadas'"
  },
  "build": {
    "appId": "com.soundmaster.app",
    "productName": "SoundMaster",
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "@tensorflow/tfjs": "^4.22.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "dgram": "^1.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "localtunnel": "^2.0.2",
    "nedb": "^1.8.0",
    "socket.io": "^4.8.3",
    "soundcraft-ui-connection": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.5"
  }
}
